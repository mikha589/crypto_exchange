<div class="fixed inset-0 w-screen h-screen bg-gray-900 text-white p-8 overflow-y-auto">
  <div class="flex justify-between items-center mb-10 border-b border-gray-800 pb-5">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">CryptoExchange MVP</h1>
      <p class="text-gray-400 mt-1">Вы вошли как: <%= current_user.email %></p>
    </div>
    <%= link_to "Выйти", destroy_user_session_path, data: { turbo_method: :delete }, class: "bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg font-medium transition" %>
  </div>

  <div class="max-w-6xl mx-auto">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Мои Балансы</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <% @wallets.each do |wallet| %>
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 flex justify-between items-center shadow-lg">
          <div>
            <span class="text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= wallet.currency %></span>
            <div class="text-3xl font-mono font-bold mt-1">
              <%= wallet.currency == 'USD' ? number_to_currency(wallet.balance) : wallet.balance %>
            </div>
          </div>
          <div class="w-12 h-12 rounded-full bg-gray-700 flex items-center justify-center font-bold text-yellow-500 text-lg">
            <%= wallet.currency[0] %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>